# usage-monitor credential overrides
# Copy to: ~/.config/usage-monitor/env   (highest priority; all keys optional)
#
# If a key is absent here, credentials are auto-reused from local agent CLIs:
#   DeepSeek / GLM / MiniMax -> ~/.local/share/opencode/auth.json or ~/.hermes/auth.json
#   Claude                   -> macOS Keychain "Claude Code-credentials" (Claude Code login)
#   Codex                    -> ~/.codex/auth.json (codex CLI login; auto-refreshed)
#   Gemini                   -> ~/.gemini/oauth_creds.json (gemini CLI login; auto-refreshed)
#
# Providers with no credentials anywhere are simply hidden from the panel.

#DEEPSEEK_API_KEY=sk-xxxx
#GLM_API_KEY=xxxx
#MINIMAX_API_KEY=xxxx
